# Required for memory_create unless agent is passed per-call.
AGENT_NAME=

# Umbrella base for ALL data. Default: sql_memory/data (relative to MCP root).
# Set to an absolute path to relocate the whole tree elsewhere.
GLOBAL_DATA_PATH=

# Per-path overrides. Leave empty to use derived defaults.
# DATABASE_PATH default:    <GLOBAL_DATA_PATH>/memory.db
# AGENT_DATA_PATH default:  <GLOBAL_DATA_PATH>/agents  (per-agent folder is
#                           always <AGENT_DATA_PATH>/<AGENT_NAME>)
DATABASE_PATH=
AGENT_DATA_PATH=

# Bundled schema file. Resolved against the MCP package root regardless.
DATABASE_SCHEMA_PATH=src/database/schema.sql
